# IT Asset Tracking Tool - Frontend Environment Variables
# Copy this file to .env and update with your values

# API Configuration
REACT_APP_API_URL=http://localhost:5000/api

# Application
REACT_APP_NAME=AssetTrack
REACT_APP_VERSION=1.0.0

# Features (enable/disable)
REACT_APP_ENABLE_GOOGLE_INTEGRATION=false
REACT_APP_ENABLE_EMAIL_REMINDERS=true
REACT_APP_ENABLE_BARCODE_SCANNING=true
